     queueEventList(device, InputEventList, nevents);
 }
 
+/*
+ * Experimental AnbryInput-only keyboard fast path.
+ *
+ * This intentionally supports only normal KeyPress/KeyRelease events from
+ * AnbryInput. It skips focus enter/leave handling and generic type dispatch.
+ * Drivers must pass X keycodes in the valid 8..255 range.
+ */
+void
+QueueAInputKey(DeviceIntPtr device, int keycode, int is_down)
+{
+    CARD32 ms;
+    InternalEvent *events = InputEventList;
+    InternalEvent *out;
+    RawDeviceEvent *raw;
+    DeviceEvent *event;
+    int prefix_events;
+    int num_events = 0;
+    int type;
+
+    if (!device || !device->enabled || !device->key || !device->focus ||
+        !device->kbdfeed || keycode < 8 || keycode > 255)
+        return;
+
+    type = is_down ? KeyPress : KeyRelease;
+
+    /*
+     * AnbryInput already ignores evdev autorepeat (value == 2), but keep the
+     * X server-side duplicate press guard for safety.
+     */
+    if (is_down && key_is_down(device, keycode, KEY_POSTED))
+        return;
+
+    out = UpdateFromMaster(events, device, DEVCHANGE_KEYBOARD_EVENT, &num_events);
+    prefix_events = num_events;
+    ms = GetTimeInMillis();
+
+    raw = &out->raw_event;
+    init_raw(device, raw, ms, type, keycode);
+    out++;
+    num_events++;
+
+    event = &out->device_event;
+    init_device_event(event, device, ms, EVENT_SOURCE_NORMAL);
+    event->detail.key = keycode;
+
+    if (is_down) {
+        event->type = ET_KeyPress;
+        set_key_down(device, keycode, KEY_POSTED);
+    }
+    else {
+        event->type = ET_KeyRelease;
+        set_key_up(device, keycode, KEY_POSTED);
+    }
+
+    out++;
+    num_events++;
+
+    if (prefix_events == 0)
+        mieqEnqueueAInputKeyPair(device, &InputEventList[0],
+                                 &InputEventList[1]);
+    else
+        queueEventList(device, InputEventList, num_events);
+}
