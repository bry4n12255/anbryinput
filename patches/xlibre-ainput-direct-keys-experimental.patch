+/*
+ * AnbryInput-only queue fast path for:
+ *   ET_RawKeyPress/Release followed by ET_KeyPress/Release.
+ */
+void
+mieqEnqueueAInputKeyPair(DeviceIntPtr pDev,
+                         InternalEvent *raw,
+                         InternalEvent *key)
+{
+    unsigned int tail;
+    size_t n_enqueued;
+
+    n_enqueued = mieqNumEnqueued(&miEventQueue);
+    if (n_enqueued + 2 >= miEventQueue.nevents) {
+        if (!mieqGrowQueue(&miEventQueue, miEventQueue.nevents << 1)) {
+            miEventQueue.dropped++;
+            return;
+        }
+    }
+
+    tail = miEventQueue.tail;
+    mieqEnqueueAInputSlot(pDev, raw, tail, 0);
+    tail = (tail + 1) % miEventQueue.nevents;
+
+    mieqEnqueueAInputSlot(pDev, key, tail, 0);
+    miEventQueue.tail = (tail + 1) % miEventQueue.nevents;
+}
