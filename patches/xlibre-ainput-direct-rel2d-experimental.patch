+static inline void
+mieqEnqueueAInputSlot(DeviceIntPtr pDev, InternalEvent *e,
+                      unsigned int tail, int isMotion)
+{
+    InternalEvent *evt = miEventQueue.events[tail].events;
+    Time time;
+
+    memcpy(evt, e, e->any.length);
+
+    time = evt->any.time;
+    if (time < miEventQueue.lastEventTime &&
+        miEventQueue.lastEventTime - time < 10000)
+        evt->any.time = miEventQueue.lastEventTime;
+
+    miEventQueue.lastEventTime = evt->any.time;
+    miEventQueue.events[tail].pScreen = pDev ? EnqueueScreen(pDev) : NULL;
+    miEventQueue.events[tail].pDev = pDev;
+    miEventQueue.lastMotion = isMotion;
+}
+
+/*
+ * AnbryInput-only queue fast path for the common pair:
+ *   ET_RawMotion followed by ET_Motion for the same device.
+ *
+ * This intentionally skips generic verification and per-event branching used
+ * by mieqEnqueue(). It must only be used by code that has already built these
+ * two exact event types and still wants normal mieq delivery semantics.
+ */
+void
+mieqEnqueueAInputMotionPair(DeviceIntPtr pDev,
+                            InternalEvent *raw,
+                            InternalEvent *motion)
+{
+    unsigned int tail;
+    size_t n_enqueued;
+
+    n_enqueued = mieqNumEnqueued(&miEventQueue);
+    if (n_enqueued + 2 >= miEventQueue.nevents) {
+        if (!mieqGrowQueue(&miEventQueue, miEventQueue.nevents << 1)) {
+            miEventQueue.dropped++;
+            return;
+        }
+    }
+
+    tail = miEventQueue.tail;
+    mieqEnqueueAInputSlot(pDev, raw, tail, 0);
+    tail = (tail + 1) % miEventQueue.nevents;
+
+    mieqEnqueueAInputSlot(pDev, motion, tail, pDev ? pDev->id : 0);
+    miEventQueue.tail = (tail + 1) % miEventQueue.nevents;
+}
