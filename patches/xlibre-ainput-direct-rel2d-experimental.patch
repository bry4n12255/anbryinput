+/*
+ * Experimental AnbryInput-only relative 2D fast path.
+ *
+ * This intentionally supports only the narrow contract AnbryInput needs:
+ * relative mouse motion on axes 0/1, no acceleration, no scroll emulation,
+ * no absolute/tablet/touchpad handling, and no generic valuator traversal.
+ *
+ * It still preserves the externally important pieces:
+ * - XI_RawMotion
+ * - XI_Motion/core pointer motion
+ * - sprite movement, clipping, barriers, and screen crossing through
+ *   miPointerSetPosition()
+ * - master pointer last coordinates
+ *
+ * Drivers must only call this for simple relative pointer motion.
+ */
+void
+QueueAInputRelativeMotion2D(DeviceIntPtr device, double dx, double dy)
+{
+    CARD32 ms = GetTimeInMillis();
+    InternalEvent *events = InputEventList;
+    InternalEvent *out;
+    RawDeviceEvent *raw;
+    DeviceEvent *event;
+    DeviceIntPtr master;
+    ScreenPtr scr;
+    ValuatorMask history_mask = {0};
+    int prefix_events;
+    int num_events = 0;
+    int barrier_events = 0;
+    double old_x, old_y;
+    double screenx, screeny;
+
+    if (!device || !device->enabled || !device->valuator ||
+        device->valuator->numAxes < 2)
+        return;
+
+    scr = miPointerGetScreen(device);
+    if (!scr)
+        return;
+
+    out = UpdateFromMaster(events, device, DEVCHANGE_POINTER_EVENT, &num_events);
+    prefix_events = num_events;
+
+    raw = &out->raw_event;
+    init_raw(device, raw, ms, MotionNotify, 0);
+    SetBit(raw->valuators.mask, 0);
+    SetBit(raw->valuators.mask, 1);
+    raw->valuators.data_raw[0] = dx;
+    raw->valuators.data_raw[1] = dy;
+    raw->valuators.data[0] = dx;
+    raw->valuators.data[1] = dy;
+    out++;
+    num_events++;
+
+    old_x = device->last.valuators[0];
+    old_y = device->last.valuators[1];
+    screenx = old_x + dx;
+    screeny = old_y + dy;
+
+    scr = miPointerSetPosition(device, Relative, &screenx, &screeny,
+                               &barrier_events, out);
+    out += barrier_events;
+    num_events += barrier_events;
+
+    history_mask.last_bit = 1;
+    history_mask.mask[0] = 0x3;
+    history_mask.valuators[0] = screenx - scr->x;
+    history_mask.valuators[1] = screeny - scr->y;
+    updateHistory(device, &history_mask, ms);
+
+    device->last.valuators[0] = screenx;
+    device->last.valuators[1] = screeny;
+
+    if (!InputDevIsMaster(device) && !InputDevIsFloating(device)) {
+        master = GetMaster(device, MASTER_POINTER);
+        if (master) {
+            master->last.valuators[0] = screenx;
+            master->last.valuators[1] = screeny;
+        }
+    }
+
+    event = &out->device_event;
+    init_device_event(event, device, ms, EVENT_SOURCE_NORMAL);
+    event->type = ET_Motion;
+    event->detail.button = 0;
+    event_set_root_coordinates(event, screenx - scr->x, screeny - scr->y);
+    SetBit(event->valuators.mask, 0);
+    SetBit(event->valuators.mask, 1);
+    event->valuators.data[0] = screenx - scr->x;
+    event->valuators.data[1] = screeny - scr->y;
+    out++;
+    num_events++;
+
+    if (prefix_events == 0 && barrier_events == 0)
+        mieqEnqueueAInputMotionPair(device, &InputEventList[0],
+                                    &InputEventList[1]);
+    else
+        queueEventList(device, InputEventList, num_events);
+}
